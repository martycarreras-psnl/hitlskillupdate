# .env — Safe to commit only when it contains 1Password references (op://...).
# NEVER commit raw secrets.
#
# Run the setup wizard to populate this file:
#   npx @pacaf/wizard-ux@latest

# Power Platform environment URLs (e.g. https://yourorg-dev.crm.dynamics.com)
PP_ENV_DEV=
PP_ENV_TEST=
PP_ENV_PROD=

# Publisher prefix (2-8 lowercase letters)
PP_PUBLISHER_PREFIX=

# Entra ID App Registration (filled by wizard)
PP_TENANT_ID=
PP_CLIENT_ID=
# PP_CLIENT_SECRET should be a 1Password reference: op://Vault/Item/field
PP_CLIENT_SECRET=

# Required at runtime by Dataverse adapters that call the *WithOrganization
# overloads on MicrosoftDataverseService. Use the same value as PP_ENV_DEV
# (no trailing slash). See .github/instructions/02-connectors.instructions.md
# > "Always call the *WithOrganization variants". Bare ListRecords / GetItem /
# CreateRecord / UpdateRecord / DeleteRecord overloads send organization=null
# and return HTTP 400 from a deployed Code App.
# VITE_DATAVERSE_URL=
